# Aria Voice Agent — Environment Variables
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to git (it's in .gitignore).

# Required for the voice agent (SmallWebRTC — no Daily key needed)
DEEPGRAM_API_KEY=your_deepgram_key
GROQ_API_KEY=your_groq_key
CARTESIA_API_KEY=your_cartesia_key
OPENAI_API_KEY=your_openai_key

# Optional — latency tuning (see ARCHITECTURE.md § Latency vs Quality Tradeoffs)
# GROQ_MODEL=llama-3.3-70b-versatile       # default: smarter, ~280ms TTFB
# DEEPGRAM_UTTERANCE_END_MS=1000           # default: safer for slow speakers
# DEEPGRAM_ENDPOINTING=250                 # default
# TTS_LOW_LATENCY=false                    # default: SENTENCE mode (more natural)

# ——— BALANCED / QUALITY (~600–700ms) ———
# DEEPGRAM_UTTERANCE_END_MS=600
# DEEPGRAM_ENDPOINTING=200

# ——— LOW LATENCY — sub-330ms (active below) ———
GROQ_MODEL=llama-3.1-8b-instant
DEEPGRAM_UTTERANCE_END_MS=300
DEEPGRAM_ENDPOINTING=150
TTS_LOW_LATENCY=true

# ——— DUAL LLM ROUTING — simple → 8B, complex → 70B ———
# ENABLE_DUAL_LLM=true
# GROQ_MODEL_FAST=llama-3.1-8b-instant
# GROQ_MODEL_SMART=llama-3.3-70b-versatile
# USE_LLM_CLASSIFIER=true   # true: 8B classifier (~50ms), false: keyword matching (0ms)

# ——— BACKCHANNELING (TODO: not implemented) ———
# ENABLE_BACKCHANNELING=true   # "mhm", "okay" during long user turns; see agent/backchanneling.py

# Optional — for observability / deployment
# LOGFIRE_TOKEN=your_logfire_token
# FLY_API_TOKEN=your_fly_token
